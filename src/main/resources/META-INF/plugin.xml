<idea-plugin>
    <id>com.ngscaffolder.ng-nx-scaffolder</id>
    <name>Angular/Nx Scaffolder</name>
    <vendor url="https://github.com/dineeek/ng-nx-scaffolder">dineeek</vendor>
    <description><![CDATA[
        Code generation plugin for Angular and Nx developers.
        Generates feature libraries (with store/facade/form/dialog/routing),
        data-access services, model interfaces, UI components, utility files,
        and Playwright E2E tests.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
                serviceImplementation="com.ngscaffolder.settings.PluginSettings"/>
        <applicationConfigurable
                instance="com.ngscaffolder.settings.PluginSettingsConfigurable"
                displayName="Angular/Nx Scaffolder"
                parentId="tools"/>
        <defaultLiveTemplates file="/liveTemplates/AngularNx.xml"/>
        <notificationGroup id="NgNxScaffolder.Notifications" displayType="BALLOON"/>
    </extensions>

    <actions>
        <group id="NgNxScaffolder.NewGroup" text="Angular/Nx" popup="true">
            <add-to-group group-id="NewGroup" anchor="last"/>

            <separator text="Nx Library Generators"/>
            <action id="NgNxScaffolder.NewFeatureLib"
                    class="com.ngscaffolder.actions.NewFeatureLibAction"
                    text="Feature Library"
                    description="Generate a feature lib with container, store, facade, form, mapper"/>
            <action id="NgNxScaffolder.NewDataAccessLib"
                    class="com.ngscaffolder.actions.NewDataAccessLibAction"
                    text="Data-Access Library"
                    description="Generate a data-access lib with HttpClient service"/>
            <action id="NgNxScaffolder.NewModelLib"
                    class="com.ngscaffolder.actions.NewModelLibAction"
                    text="Model Library"
                    description="Generate a model lib with interface"/>
            <action id="NgNxScaffolder.NewUiLib"
                    class="com.ngscaffolder.actions.NewUiLibAction"
                    text="UI Library"
                    description="Generate a UI lib with standalone example component"/>
            <action id="NgNxScaffolder.NewUtilLib"
                    class="com.ngscaffolder.actions.NewUtilLibAction"
                    text="Util Library"
                    description="Generate a util lib with utility file"/>

            <separator text="E2E Testing"/>
            <action id="NgNxScaffolder.NewPlaywrightTest"
                    class="com.ngscaffolder.actions.NewPlaywrightTestAction"
                    text="Playwright E2E Test"
                    description="Generate Playwright E2E test with POM"/>
        </group>
    </actions>
</idea-plugin>
